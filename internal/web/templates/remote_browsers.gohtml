{{ define "remote_browsers.gohtml" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Remote Browsers - Conductor</title>
    {{ template "styles" . }}
</head>
<body>
    {{ template "navbar" . }}
    <div class="container">

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <h1 class="page-title" style="margin:0;">Remote Browsers</h1>
    <a href="/remote-browsers/new" class="btn btn-primary">+ New Remote Browser</a>
</div>

{{ if .Flash }}
<div class="alert alert-success" style="margin-bottom:1rem;">{{ .Flash }}</div>
{{ end }}

{{ if .Error }}
<div class="alert alert-danger" style="margin-bottom:1rem;">{{ .Error }}</div>
{{ end }}

{{ if .NewForm }}
<div class="card" style="margin-bottom:1.5rem; padding:1.5rem;">
    <h2 style="margin:0 0 1.25rem; font-size:1.1rem;">New Remote Browser</h2>
    <form method="POST" action="/remote-browsers">
        <div class="form-group">
            <label for="name">Name <span style="color:#ef4444;">*</span></label>
            <input class="form-control" type="text" id="name" name="name"
                   value="{{ .Browser.Name }}" placeholder="e.g. Playwright Service" required />
        </div>
        <div class="form-group">
            <label for="endpoint_url">DevTools Endpoint URL <span style="color:#ef4444;">*</span></label>
            <input class="form-control" type="text" id="endpoint_url" name="endpoint_url"
                   value="{{ .Browser.EndpointURL }}" placeholder="ws://chrome.example.com:9222/devtools/browser/..." required />
            <small style="color:#64748b; font-size:0.775rem; display:block; margin-top:0.25rem;">
                Must be a WebSocket endpoint (<code>ws://</code> or <code>wss://</code>) for a Chromium DevTools target.
            </small>
        </div>
        <div style="display:flex; gap:0.75rem;">
            <button type="submit" class="btn btn-primary">Create Remote Browser</button>
            <a href="/remote-browsers" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
{{ end }}

{{ if .EditBrowser }}
<div class="card" style="margin-bottom:1.5rem; padding:1.5rem;">
    <h2 style="margin:0 0 1.25rem; font-size:1.1rem;">Edit Remote Browser</h2>
    <form method="POST" action="/remote-browsers/{{ .EditBrowser.ID }}">
        <div class="form-group">
            <label for="name_edit">Name <span style="color:#ef4444;">*</span></label>
            <input class="form-control" type="text" id="name_edit" name="name"
                   value="{{ .EditBrowser.Name }}" required />
        </div>
        <div class="form-group">
            <label for="endpoint_url_edit">DevTools Endpoint URL <span style="color:#ef4444;">*</span></label>
            <input class="form-control" type="text" id="endpoint_url_edit" name="endpoint_url"
                   value="{{ .EditBrowser.EndpointURL }}" required />
        </div>
        <div style="display:flex; gap:0.75rem;">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/remote-browsers" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
{{ end }}

{{ if .Browsers }}
<div class="card" style="padding:0; overflow:hidden;">
    <table class="table" style="margin:0;">
        <thead>
            <tr>
                <th>Name</th>
                <th>Endpoint URL</th>
                <th style="text-align:center;">Actions</th>
            </tr>
        </thead>
        <tbody>
        {{ range .Browsers }}
        <tr>
            <td style="font-weight:500; color:#e2e8f0;">{{ .Name }}</td>
            <td style="font-size:0.8125rem; color:#94a3b8; font-family:monospace;">{{ .EndpointURL }}</td>
            <td style="text-align:center; white-space:nowrap;">
                <a href="/remote-browsers/{{ .ID }}/edit" class="btn btn-sm btn-ghost">Edit</a>
                <form method="POST" action="/remote-browsers/{{ .ID }}/delete" style="display:inline;"
                      onsubmit="return confirm('Delete remote browser &quot;{{ .Name | js }}&quot;?')">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
        {{ end }}
        </tbody>
    </table>
</div>
{{ else if not .NewForm }}
{{ if not .EditBrowser }}
<div class="card" style="text-align:center; padding:2.5rem; color:#64748b;">
    <p style="font-size:1rem; margin-bottom:1rem;">No remote browsers configured yet.</p>
    <a href="/remote-browsers/new" class="btn btn-primary">Add your first remote browser</a>
</div>
{{ end }}
{{ end }}

    </div>
</body>
</html>
{{ end }}
